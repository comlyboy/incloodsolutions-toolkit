{
	"name": "@incloodsolutions/toolkit",
	"version": "0.1.2",
	"description": "A lightweight, framework-agnostic toolkit providing common utilities, helpers, and abstractions for building scalable JavaScript and TypeScript applications.",
	"main": "dist/index.js",
	"author": "Inclood Solutions",
	"private": false,
	"license": "MIT",
	"files": [
		"dist",
		"README.md"
	],
	"keywords": [
		"toolkit",
		"utilities",
		"javascript",
		"typescript",
		"helpers",
		"library",
		"functions",
		"open-source",
		"shared",
		"incloodsolutions"
	],
	"scripts": {
		"prebuild": "rimraf dist",
		"build:cdk": "rimraf dist && mkdir -p dist/nodejs && cp package*.json dist/nodejs && npm i --omit=dev --prefix dist/nodejs && du -sh dist/nodejs/node_modules",
		"build:cjs": "tsc -p tsconfig.cjs.json",
		"build:esm": "tsc -p tsconfig.esm.json",
		"build:tsup": "tsup",
		"build": "tsc",
		"version:patch": "npm version patch --no-git-tag-version",
		"package": "npm run build && npm pack",
		"format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
		"lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
		"test": "jest"
	},
	"dependencies": {
		"axios": "^1.16.1",
		"bwip-js": "^4.10.1",
		"countries-and-timezones": "^3.9.0",
		"handlebars": "^4.7.9",
		"libphonenumber-js": "^1.13.2",
		"lodash.clonedeep": "^4.5.0",
		"qr-code-styling": "^1.9.2",
		"tslib": "^2.8.1",
		"uuid": "^14.0.0",
		"validator": "^13.15.35",
		"xml2js": "^0.6.2"
	},
	"devDependencies": {
		"@esbuild-plugins/tsconfig-paths": "^0.1.2",
		"@types/jest": "^30.0.0",
		"@types/lodash.clonedeep": "^4.5.9",
		"@types/node": "^25.9.1",
		"@types/validator": "^13.15.10",
		"@types/xml2js": "^0.4.14",
		"@typescript-eslint/eslint-plugin": "^8.59.4",
		"@typescript-eslint/parser": "^8.59.4",
		"esbuild": "^0.28.0",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"jest": "^30.4.2",
		"prettier": "^3.8.3",
		"rimraf": "^6.1.3",
		"source-map-support": "^0.5.21",
		"ts-jest": "^29.4.11",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"rootDir": ".",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"collectCoverageFrom": [
			"**/*.(t|j)s"
		],
		"coverageDirectory": "./coverage",
		"testEnvironment": "node",
		"roots": [
			"<rootDir>/src/"
		]
	}
}