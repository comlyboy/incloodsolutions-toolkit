{
	"name": "@incloodsolutions/react-toolkit",
	"version": "0.0.4",
	"description": "A collection of reusable React utilities, hooks, and components designed to accelerate development and improve code consistency across React applications.",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"author": "Inclood Solutions",
	"private": false,
	"license": "MIT",
	"files": [
		"dist",
		"README.md"
	],
	"keywords": [
		"components",
		"react",
		"react-hooks",
		"react-components",
		"react-toolkit",
		"ui",
		"frontend",
		"library",
		"typescript",
		"javascript",
		"utilities",
		"incloodsolutions"
	],
	"scripts": {
		"prebuild": "rimraf dist",
		"build": "tsup",
		"buildd": "npm run prebuild && npx vite build",
		"version:patch": "npm version patch --no-git-tag-version",
		"package": "npm run build && npm pack",
		"format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
		"lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
		"test": "jest"
	},
	"dependencies": {
		"@hookform/resolvers": "^5.4.0",
		"@incloodsolutions/toolkit": "^0.1.5",
		"clsx": "^2.1.1",
		"joi": "^18.2.1",
		"radix-ui": "^1.5.0",
		"react-hook-form": "^7.77.0",
		"react-use": "^17.6.0",
		"tailwind-merge": "^3.6.0",
		"usehooks-ts": "^3.1.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"prettier": "^3.8.3",
		"react": ">=19.2.7",
		"react-dom": ">=19.2.7",
		"react-router-dom": "^7.17.0",
		"rimraf": "^6.1.3",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"react": ">=18.0.0",
		"react-dom": ">=18.0.0",
		"react-router-dom": ">=7.10.1"
	},
	"peerDependenciesMeta": {
		"react-dom": {
			"optional": true
		},
		"react-router-dom": {
			"optional": true
		}
	}
}
