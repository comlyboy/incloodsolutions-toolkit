{
	"name": "@incloodsolutions/devkit",
	"version": "0.0.1",
	"description": "A toolkit containing aws utility, helper, config, interfaces.",
	"main": "dist/index.js",
	"author": "Inclood Solutions",
	"private": false,
	"license": "MIT",
	"files": [
		"dist",
		"README.md"
	],
	"keywords": [
		"aws",
		"aws-cdk",
		"node",
		"linting",
		"utilities",
		"toolkit",
		"javascript",
		"typescript",
		"prettier",
		"helpers",
		"library",
		"incloodsolutions"
	],
	"scripts": {
		"prebuild": "rimraf dist",
		"build:cdk": "rimraf dist && mkdir -p dist/nodejs && cp package*.json dist/nodejs && npm i --omit=dev --prefix dist/nodejs && du -sh dist/nodejs/node_modules",
		"buildd": "tsc",
		"build": "tsup",
		"version:patch": "npm version patch --no-git-tag-version",
		"package": "npm run build && npm pack",
		"format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
		"lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
		"test": "jest"
	},
	"dependencies": {
		"@incloodsolutions/toolkit": "^0.1.3",
		"aws-cdk-lib": "^2.257.0",
		"constructs": "^10.6.0",
		"tslib": "^2.8.1"
	},
	"devDependencies": {
		"@esbuild-plugins/tsconfig-paths": "^0.1.2",
		"@types/jest": "^30.0.0",
		"@types/node": "^25.9.1",
		"@typescript-eslint/eslint-plugin": "^8.60.1",
		"@typescript-eslint/parser": "^8.60.1",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.6",
		"jest": "^30.4.2",
		"prettier": "^3.8.3",
		"rimraf": "^6.1.3",
		"source-map-support": "^0.5.21",
		"ts-jest": "^29.4.11",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3"
	},
	"peerDependenciesMeta": {},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"rootDir": ".",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"collectCoverageFrom": [
			"**/*.(t|j)s"
		],
		"coverageDirectory": "./coverage",
		"testEnvironment": "node",
		"roots": [
			"<rootDir>/src/"
		]
	}
}